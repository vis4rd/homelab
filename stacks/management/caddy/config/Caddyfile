{
	auto_https disable_redirects
	admin 0.0.0.0:2019

    log {
        output file /etc/caddy/logs/latest.log {
			roll_size 10MiB
		}
        format console
        level DEBUG
    }
}

(ovh_dns_challenge) {
    tls {
        dns ovh {
            endpoint ovh-ca
            application_key {env.OVH_APPLICATION_KEY}
            application_secret {env.OVH_APPLICATION_SECRET}
            consumer_key {env.OVH_CONSUMER_KEY}
        }
    }
}

http://modem.homelab.local,
http://modem.home.arpa {
	reverse_proxy 192.168.1.1
}

http://router.homelab.local,
http://router.home.arpa {
	reverse_proxy 192.168.2.1
}

http://home.homelab.local,
http://home.home.arpa {
	reverse_proxy homepage:3000
}

http://dns.homelab.local,
http://dns.home.arpa {
	reverse_proxy pihole:80
}

http://docker.homelab.local,
http://docker.home.arpa {
	reverse_proxy dockhand:3000
}

