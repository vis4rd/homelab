http://spotify.homelab.local,
http://spotify.home.arpa {
	redir https://yourspotify.{$EXTERNAL_DOMAIN}
}

yourspotify.{$EXTERNAL_DOMAIN} {
	@client {
		path /
		path /manifest.json /*.ico /*.js /*.png
		path /_next/* /static/*
		path /login /logout
	}

    reverse_proxy @client your_spotify_client:3000
    reverse_proxy your_spotify_server:8080

	import ovh_dns_challenge
}

# Return HTTP Status 404 for all undefined subdomains
http://*.homelab.local,
http://*.home.arpa {
	abort
}
