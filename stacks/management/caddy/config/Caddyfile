router.internal {
	reverse_proxy 192.168.1.1
}

home.internal {
	reverse_proxy homepage:3000
}

dns.internal {
	reverse_proxy pihole:80
}

docker.internal {
	reverse_proxy dockge:5001
}

http://router.internal,
http://home.internal,
http://dns.internal,
http://docker.internal {
    redir https://{host}{uri} 301
}

# Return HTTP Status 404 for all undefined subdomains
http://*.internal, https://*.internal {
	respond "" 404
}
